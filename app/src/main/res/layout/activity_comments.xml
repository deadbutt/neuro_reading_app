<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:orientation="vertical">

    <!-- ==================== 1. 顶部栏 ==================== -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/detail_top_bar_height"
        android:background="@color/white"
        android:elevation="@dimen/elevation_2dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="@dimen/detail_top_icon_size"
            android:layout_height="@dimen/detail_top_icon_size"
            android:layout_centerVertical="true"
            android:contentDescription="@string/comments_title"
            android:padding="4dp"
            android:src="@drawable/ic_back_arrow" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/comments_title"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_large"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_comment_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="@string/comments_count"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/comment_top_bar_count_size" />
        </LinearLayout>
    </RelativeLayout>

    <!-- ==================== 2. 排序切换栏 ==================== -->
    <LinearLayout
        android:id="@+id/ll_sort_tabs"
        android:layout_width="match_parent"
        android:layout_height="@dimen/tab_height"
        android:background="@color/white"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <TextView
                android:id="@+id/tv_sort_hot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/comments_sort_hot"
                android:textColor="@color/primary_red"
                android:textSize="@dimen/tab_text_size"
                android:textStyle="bold" />

            <View
                android:id="@+id/v_indicator_hot"
                android:layout_width="@dimen/tab_indicator_width"
                android:layout_height="@dimen/tab_indicator_height"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_tab_indicator" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_sort_new"
            style="@style/TabTextStyle"
            android:layout_height="44dp"
            android:text="@string/comments_sort_new" />

        <TextView
            android:id="@+id/tv_sort_author"
            style="@style/TabTextStyle"
            android:layout_height="match_parent"
            android:text="@string/comments_sort_author" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/divider_height"
        android:background="@color/divider" />

    <!-- ==================== 3. 评论列表 (可下拉刷新) ==================== -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/srl_comments"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_comments"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/app_background"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- ==================== 4. 底部评论输入栏 ==================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/comment_bottom_bar_height"
        android:background="@drawable/bg_comment_bottom_bar"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/padding_horizontal"
        android:paddingEnd="8dp">

        <EditText
            android:id="@+id/et_comment_input"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:background="@drawable/bg_comment_input"
            android:hint="@string/comments_hint"
            android:inputType="text"
            android:maxLines="1"
            android:paddingStart="14dp"
            android:paddingEnd="8dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="@dimen/text_body" />

        <ImageView
            android:id="@+id/iv_emoji"
            android:layout_width="@dimen/comment_input_icon_size"
            android:layout_height="@dimen/comment_input_icon_size"
            android:layout_marginStart="8dp"
            android:contentDescription="@string/comments_hint"
            android:padding="3dp"
            android:src="@drawable/ic_emoji" />

        <ImageView
            android:id="@+id/iv_image"
            android:layout_width="@dimen/comment_input_icon_size"
            android:layout_height="@dimen/comment_input_icon_size"
            android:layout_marginStart="2dp"
            android:contentDescription="@string/comments_hint"
            android:padding="3dp"
            android:src="@drawable/ic_image" />

        <TextView
            android:id="@+id/btn_send"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_send_btn"
            android:gravity="center"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="@string/comments_send"
            android:textColor="@color/white"
            android:textSize="@dimen/text_small" />
    </LinearLayout>

</LinearLayout>
