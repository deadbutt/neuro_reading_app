<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:orientation="vertical">

    <!-- ==================== 1. 顶部栏 ==================== -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/detail_top_bar_height"
        android:background="@color/white"
        android:elevation="@dimen/elevation_2dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <ImageView
            android:id="@+id/iv_settings_back"
            android:layout_width="@dimen/detail_top_icon_size"
            android:layout_height="@dimen/detail_top_icon_size"
            android:layout_centerVertical="true"
            android:contentDescription="@string/rs_title"
            android:padding="4dp"
            android:src="@drawable/ic_back_arrow" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/rs_title"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_large"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_reset_default"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentEnd="true"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="@string/rs_reset_default"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_body" />
    </RelativeLayout>

    <!-- ==================== 可滚动内容区域 ==================== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/padding_horizontal"
            android:paddingEnd="@dimen/padding_horizontal"
            android:paddingTop="@dimen/rs_section_margin"
            android:paddingBottom="@dimen/rs_section_margin">

            <!-- ==================== 2. 字体选择区域 ==================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rs_preview_card"
                android:orientation="vertical"
                android:elevation="@dimen/elevation_1dp"
                android:paddingStart="@dimen/padding_horizontal"
                android:paddingEnd="@dimen/padding_horizontal"
                android:paddingTop="@dimen/rs_section_padding_v"
                android:paddingBottom="4dp"
                android:layout_marginBottom="@dimen/rs_section_margin">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/rs_section_font"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/section_title_size"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="8dp">

                        <LinearLayout
                            android:id="@+id/ll_font_default"
                            android:layout_width="@dimen/rs_font_option_width"
                            android:layout_height="@dimen/rs_font_option_height"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_rs_font_option_selected"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="Aa"
                                android:textColor="@color/primary_red"
                                android:textSize="26sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/rs_font_default"
                                android:textColor="@color/primary_red"
                                android:textSize="@dimen/text_micro" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/ll_font_siyuan"
                            android:layout_width="@dimen/rs_font_option_width"
                            android:layout_height="@dimen/rs_font_option_height"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_rs_font_option"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="Aa"
                                android:textColor="@color/text_primary"
                                android:textSize="26sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/rs_font_siyuan"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_micro" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/ll_font_kaiti"
                            android:layout_width="@dimen/rs_font_option_width"
                            android:layout_height="@dimen/rs_font_option_height"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_rs_font_option"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="Aa"
                                android:textColor="@color/text_primary"
                                android:textSize="26sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/rs_font_kaiti"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_micro" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/ll_font_fangsong"
                            android:layout_width="@dimen/rs_font_option_width"
                            android:layout_height="@dimen/rs_font_option_height"
                            android:background="@drawable/bg_rs_font_option"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="Aa"
                                android:textColor="@color/text_primary"
                                android:textSize="26sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/rs_font_fangsong"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_micro" />
                        </LinearLayout>
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <!-- ==================== 3. 字号调整区域 ==================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rs_preview_card"
                android:orientation="vertical"
                android:elevation="@dimen/elevation_1dp"
                android:paddingStart="@dimen/padding_horizontal"
                android:paddingEnd="@dimen/padding_horizontal"
                android:paddingTop="@dimen/rs_section_padding_v"
                android:paddingBottom="12dp"
                android:layout_marginBottom="@dimen/rs_section_margin">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/rs_section_size"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/section_title_size"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_size_small"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:gravity="center"
                        android:text="A⁻"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <SeekBar
                        android:id="@+id/sb_font_size"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:layout_weight="1"
                        android:max="8"
                        android:progress="3"
                        android:progressDrawable="@drawable/bg_shelf_progress"
                        android:splitTrack="false"
                        android:thumb="@drawable/bg_reader_seekbar_thumb"
                        android:thumbOffset="0dp" />

                    <TextView
                        android:id="@+id/btn_size_large"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:gravity="center"
                        android:text="A⁺"
                        android:textColor="@color/text_primary"
                        android:textSize="19sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_preview_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@color/white"
                    android:gravity="center"
                    android:padding="16dp"
                    android:text="@string/rs_preview_text"
                    android:textColor="@color/reader_text"
                    android:textSize="@dimen/rs_preview_text_size" />
            </LinearLayout>

            <!-- ==================== 4. 背景色区域 ==================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rs_preview_card"
                android:orientation="vertical"
                android:elevation="@dimen/elevation_1dp"
                android:paddingStart="@dimen/padding_horizontal"
                android:paddingEnd="@dimen/padding_horizontal"
                android:paddingTop="@dimen/rs_section_padding_v"
                android:paddingBottom="12dp"
                android:layout_marginBottom="@dimen/rs_section_margin">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/rs_section_bg"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/section_title_size"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="4dp">

                        <FrameLayout
                            android:id="@+id/fl_bg_day"
                            android:layout_width="@dimen/rs_color_circle_size"
                            android:layout_height="@dimen/rs_color_circle_size"
                            android:layout_marginEnd="@dimen/rs_color_circle_margin">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_rs_color_selected" />

                            <View
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:background="@drawable/bg_rs_color_circle" />
                        </FrameLayout>

                        <FrameLayout
                            android:id="@+id/fl_bg_night"
                            android:layout_width="@dimen/rs_color_circle_size"
                            android:layout_height="@dimen/rs_color_circle_size"
                            android:layout_marginEnd="@dimen/rs_color_circle_margin">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_rs_color_circle"
                                android:layout_gravity="center" />

                            <View
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:background="@color/reader_bg_night" />
                        </FrameLayout>

                        <FrameLayout
                            android:id="@+id/fl_bg_eye"
                            android:layout_width="@dimen/rs_color_circle_size"
                            android:layout_height="@dimen/rs_color_circle_size"
                            android:layout_marginEnd="@dimen/rs_color_circle_margin">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_rs_color_circle"
                                android:layout_gravity="center" />

                            <View
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:background="@color/reader_bg_eye" />
                        </FrameLayout>

                        <FrameLayout
                            android:id="@+id/fl_bg_parchment"
                            android:layout_width="@dimen/rs_color_circle_size"
                            android:layout_height="@dimen/rs_color_circle_size">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_rs_color_circle"
                                android:layout_gravity="center" />

                            <View
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:background="@color/reader_bg_parchment" />
                        </FrameLayout>
                    </LinearLayout>
                </HorizontalScrollView>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="@dimen/rs_color_circle_size"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/rs_color_circle_margin"
                        android:gravity="center"
                        android:text="@string/rs_bg_day"
                        android:textColor="@color/primary_red"
                        android:textSize="@dimen/text_micro" />

                    <TextView
                        android:layout_width="@dimen/rs_color_circle_size"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/rs_color_circle_margin"
                        android:gravity="center"
                        android:text="@string/rs_bg_night"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_micro" />

                    <TextView
                        android:layout_width="@dimen/rs_color_circle_size"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/rs_color_circle_margin"
                        android:gravity="center"
                        android:text="@string/rs_bg_eye"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_micro" />

                    <TextView
                        android:layout_width="@dimen/rs_color_circle_size"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/rs_bg_parchment"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_micro" />
                </LinearLayout>
            </LinearLayout>

            <!-- ==================== 5. 翻页方式区域 ==================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rs_preview_card"
                android:orientation="vertical"
                android:elevation="@dimen/elevation_1dp"
                android:paddingStart="@dimen/padding_horizontal"
                android:paddingEnd="@dimen/padding_horizontal"
                android:paddingTop="@dimen/rs_section_padding_v"
                android:paddingBottom="12dp"
                android:layout_marginBottom="@dimen/rs_section_margin">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/rs_section_flip"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/section_title_size"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingBottom="4dp">

                    <TextView
                        android:id="@+id/tv_flip_sim"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/rs_flip_option_height"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_rs_flip_option_selected"
                        android:gravity="center"
                        android:text="@string/rs_flip_sim"
                        android:textColor="@color/primary_red"
                        android:textSize="@dimen/book_author_size" />

                    <TextView
                        android:id="@+id/tv_flip_cover"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/rs_flip_option_height"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_rs_flip_option"
                        android:gravity="center"
                        android:text="@string/rs_flip_cover"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/book_author_size" />

                    <TextView
                        android:id="@+id/tv_flip_slide"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/rs_flip_option_height"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_rs_flip_option"
                        android:gravity="center"
                        android:text="@string/rs_flip_slide"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/book_author_size" />

                    <TextView
                        android:id="@+id/tv_flip_none"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/rs_flip_option_height"
                        android:layout_weight="1"
                        android:background="@drawable/bg_rs_flip_option"
                        android:gravity="center"
                        android:text="@string/rs_flip_none"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/book_author_size" />
                </LinearLayout>
            </LinearLayout>

            <!-- ==================== 6. 其他开关区域 ==================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rs_preview_card"
                android:orientation="vertical"
                android:elevation="@dimen/elevation_1dp"
                android:paddingStart="@dimen/padding_horizontal"
                android:paddingEnd="@dimen/padding_horizontal"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_marginBottom="@dimen/rs_section_margin">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/rs_switch_item_height"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="@string/rs_switch_brightness"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body" />

                    <Switch
                        android:id="@+id/sw_brightness"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:checked="true"
                        android:thumbTint="@color/white"
                        android:trackTint="@color/primary_red" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/divider_height"
                    android:background="@color/divider" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/rs_switch_item_height"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="@string/rs_switch_volume"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body" />

                    <Switch
                        android:id="@+id/sw_volume"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:checked="true"
                        android:thumbTint="@color/white"
                        android:trackTint="@color/primary_red" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/divider_height"
                    android:background="@color/divider" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/rs_switch_item_height"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="@string/rs_switch_progress"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body" />

                    <Switch
                        android:id="@+id/sw_progress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:checked="true"
                        android:thumbTint="@color/white"
                        android:trackTint="@color/primary_red" />
                </RelativeLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
