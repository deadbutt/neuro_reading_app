<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:orientation="vertical">

    <!-- ==================== 1. 顶部栏 ==================== -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/detail_top_bar_height"
        android:background="@color/white"
        android:elevation="@dimen/elevation_2dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <ImageView
            android:id="@+id/iv_shelf_back"
            android:layout_width="@dimen/detail_top_icon_size"
            android:layout_height="@dimen/detail_top_icon_size"
            android:layout_centerVertical="true"
            android:contentDescription="@string/shelf_title"
            android:padding="4dp"
            android:src="@drawable/ic_back_arrow" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/shelf_title"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_large"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_shelf_edit"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentEnd="true"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:text="@string/shelf_edit"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_body" />
    </RelativeLayout>

    <!-- ==================== 2. Tab 切换栏 ==================== -->
    <LinearLayout
        android:id="@+id/ll_shelf_tabs"
        android:layout_width="match_parent"
        android:layout_height="@dimen/tab_height"
        android:background="@color/white"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <TextView
                android:id="@+id/tv_shelf_tab_reading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/shelf_tab_reading"
                android:textColor="@color/primary_red"
                android:textSize="@dimen/tab_text_size"
                android:textStyle="bold" />

            <View
                android:id="@+id/v_shelf_indicator_reading"
                android:layout_width="@dimen/tab_indicator_width"
                android:layout_height="@dimen/tab_indicator_height"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_tab_indicator" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_shelf_tab_read"
            style="@style/TabTextStyle"
            android:layout_height="match_parent"
            android:text="@string/shelf_tab_read" />

        <TextView
            android:id="@+id/tv_shelf_tab_subscribe"
            style="@style/TabTextStyle"
            android:layout_height="44dp"
            android:text="@string/shelf_tab_subscribe" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/divider_height"
        android:background="@color/divider" />

    <!-- ==================== 3. 书架列表 + 空状态 ==================== -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_shelf"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/app_background"
            android:clipToPadding="false"
            android:paddingTop="2dp"
            android:paddingBottom="60dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <LinearLayout
            android:id="@+id/ll_shelf_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/app_background"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageView
                android:layout_width="@dimen/shelf_empty_icon_size"
                android:layout_height="@dimen/shelf_empty_icon_size"
                android:contentDescription="@string/shelf_empty_title"
                android:src="@drawable/ic_shelf_empty" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/shelf_empty_title"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/shelf_empty_text_size" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/shelf_empty_hint"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/text_small" />

            <TextView
                android:id="@+id/btn_shelf_go"
                android:layout_width="120dp"
                android:layout_height="40dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_shelf_empty_btn"
                android:gravity="center"
                android:text="@string/shelf_empty_btn"
                android:textColor="@color/white"
                android:textSize="@dimen/text_body" />
        </LinearLayout>
    </FrameLayout>

    <!-- ==================== 4. 编辑模式底部栏 ==================== -->
    <LinearLayout
        android:id="@+id/ll_shelf_edit_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/shelf_edit_bar_height"
        android:background="@color/bottom_nav_bg"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/padding_horizontal"
        android:paddingEnd="@dimen/padding_horizontal"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/ll_select_all"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingEnd="8dp">

            <ImageView
                android:id="@+id/iv_edit_select_all"
                android:layout_width="@dimen/shelf_checkbox_size"
                android:layout_height="@dimen/shelf_checkbox_size"
                android:contentDescription="@string/shelf_select_all"
                android:src="@drawable/ic_shelf_checkbox_unchecked" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/shelf_select_all"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body" />
        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/btn_shelf_delete"
            android:layout_width="@dimen/shelf_delete_btn_width"
            android:layout_height="34dp"
            android:background="@drawable/bg_shelf_delete_btn"
            android:gravity="center"
            android:text="@string/shelf_delete"
            android:textColor="@color/white"
            android:textSize="@dimen/text_body" />
    </LinearLayout>

</LinearLayout>
