<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:orientation="horizontal"
    android:paddingStart="@dimen/padding_horizontal"
    android:paddingEnd="@dimen/padding_horizontal"
    android:paddingTop="@dimen/comment_item_padding_vertical"
    android:paddingBottom="@dimen/comment_item_padding_vertical">

    <FrameLayout
        android:layout_width="@dimen/comment_avatar_size"
        android:layout_height="@dimen/comment_avatar_size">

        <ImageView
            android:id="@+id/iv_comment_avatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_avatar_placeholder"
            android:contentDescription="@string/comments_title"
            android:scaleType="centerCrop" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_avatar_ring" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/item_spacing"
        android:layout_weight="1"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/ll_name_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_toStartOf="@+id/tv_comment_time"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_comment_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/comment_name_text_size"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_author_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/comment_author_badge_height"
                    android:layout_marginStart="@dimen/comment_name_badge_gap"
                    android:background="@drawable/bg_author_badge"
                    android:gravity="center"
                    android:paddingStart="@dimen/comment_author_badge_padding"
                    android:paddingEnd="@dimen/comment_author_badge_padding"
                    android:text="@string/comment_author_badge"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_micro" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_comment_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/comment_time_text_size" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tv_comment_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="3dp"
            android:textColor="@color/tab_inactive"
            android:textSize="@dimen/comment_content_text_size" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/ll_like"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <ImageView
                    android:id="@+id/iv_comment_like"
                    android:layout_width="@dimen/comment_like_icon_size"
                    android:layout_height="@dimen/comment_like_icon_size"
                    android:contentDescription="@string/comments_title"
                    android:src="@drawable/ic_heart_border" />

                <TextView
                    android:id="@+id/tv_comment_likes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="3dp"
                    android:textColor="@color/like_text"
                    android:textSize="@dimen/comment_action_text_size" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_reply"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:contentDescription="@string/comments_reply"
                    android:src="@drawable/ic_comment" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="3dp"
                    android:text="@string/comments_reply"
                    android:textColor="@color/like_text"
                    android:textSize="@dimen/comment_action_text_size" />
            </LinearLayout>
        </LinearLayout>

        <!-- 回复列表容器 -->
        <LinearLayout
            android:id="@+id/ll_replies"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_reply_container"
            android:orientation="vertical"
            android:padding="10dp"
            android:visibility="gone" />

        <!-- 查看更多回复 -->
        <TextView
            android:id="@+id/tv_view_more_replies"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/primary_red"
            android:textSize="13sp"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
