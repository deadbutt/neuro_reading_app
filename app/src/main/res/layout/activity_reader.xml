<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dl_reader"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- ==================== 主内容区域 ==================== -->
    <FrameLayout
        android:id="@+id/fl_reader_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/reader_bg_parchment">

        <!-- 1. 章节正文内容（单一RecyclerView实现无限滚动） -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_reader_body"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="56dp"
            android:paddingBottom="72dp"
            android:scrollbars="none" />

        <!-- 2. 顶部控制面板 -->
        <LinearLayout
            android:id="@+id/ll_reader_top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:background="@drawable/bg_reader_top_bar"
            android:elevation="@dimen/elevation_4dp"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- 顶部工具栏 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/reader_top_bar_height"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <ImageView
                    android:id="@+id/iv_reader_back"
                    android:layout_width="@dimen/reader_bar_icon_size"
                    android:layout_height="match_parent"
                    android:layout_alignParentStart="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/comments_title"
                    android:padding="13dp"
                    android:src="@drawable/ic_back_arrow" />

                <TextView
                    android:id="@+id/tv_reader_top_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/iv_reader_toc"
                    android:layout_width="@dimen/reader_bar_icon_size"
                    android:layout_height="match_parent"
                    android:layout_toStartOf="@+id/iv_reader_more"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/reader_drawer_title"
                    android:padding="13dp"
                    android:src="@drawable/ic_reader_toc" />

                <ImageView
                    android:id="@+id/iv_reader_more"
                    android:layout_width="@dimen/reader_bar_icon_size"
                    android:layout_height="match_parent"
                    android:layout_alignParentEnd="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/comments_title"
                    android:padding="13dp"
                    android:src="@drawable/ic_more_menu" />
            </RelativeLayout>

            <!-- 字体大小调节栏 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="字号"
                    android:textColor="@color/black"
                    android:textSize="14sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/btn_font_small"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_reader_font_btn"
                    android:gravity="center"
                    android:text="A⁻"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_font_size_preview"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="16"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_font_large"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_reader_font_btn"
                    android:gravity="center"
                    android:text="A⁺"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- 3. 底部控制面板 -->
        <LinearLayout
            android:id="@+id/ll_reader_bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_reader_bottom_bar"
            android:elevation="@dimen/elevation_4dp"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- 亮度调节 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_reader_brightness_low"
                    android:contentDescription="亮度低" />

                <SeekBar
                    android:id="@+id/sb_brightness"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="50"
                    android:progressDrawable="@drawable/bg_reader_seekbar"
                    android:splitTrack="false"
                    android:thumb="@drawable/bg_reader_seekbar_thumb" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_reader_brightness_high"
                    android:contentDescription="亮度高" />
            </LinearLayout>

            <!-- 功能按钮行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <LinearLayout
                    android:id="@+id/ll_btn_catalog"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_reader_toc"
                        android:contentDescription="目录" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="目录"
                        android:textColor="@color/black"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_btn_night_mode"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/iv_night_mode_icon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_reader_night"
                        android:contentDescription="夜间模式" />

                    <TextView
                        android:id="@+id/tv_night_mode_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="夜间"
                        android:textColor="@color/black"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_btn_settings"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_reader_settings"
                        android:contentDescription="设置" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="设置"
                        android:textColor="@color/black"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_btn_prev"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_arrow_left"
                        android:contentDescription="上一章" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="上一章"
                        android:textColor="@color/black"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_btn_next"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_arrow_right"
                        android:contentDescription="下一章" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="下一章"
                        android:textColor="@color/black"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 进度条 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reader_progress"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

                <SeekBar
                    android:id="@+id/sb_reader_progress"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/reader_seekbar_height"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="35"
                    android:progressDrawable="@drawable/bg_reader_seekbar"
                    android:splitTrack="false"
                    android:thumb="@drawable/bg_reader_seekbar_thumb"
                    android:thumbOffset="0dp" />

                <TextView
                    android:id="@+id/tv_reader_progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="35%"
                    android:textColor="@color/black"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 4. 中间点击区域：只占屏幕中间一小条 -->
        <View
            android:id="@+id/v_touch_overlay"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true" />
    </FrameLayout>

    <!-- ==================== 5. 侧边章节目录（DrawerLayout 右侧抽屉） ==================== -->
    <LinearLayout
        android:id="@+id/ll_reader_drawer"
        android:layout_width="@dimen/reader_drawer_width"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/white"
        android:elevation="@dimen/elevation_4dp"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/profile_menu_item_height"
            android:paddingStart="@dimen/padding_horizontal"
            android:paddingEnd="@dimen/padding_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="@string/reader_drawer_title"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_large"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/iv_drawer_close"
                android:layout_width="@dimen/reader_bar_icon_size"
                android:layout_height="@dimen/reader_bar_icon_size"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:contentDescription="@string/reader_drawer_title"
                android:padding="4dp"
                android:src="@drawable/ic_arrow_right" />
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/divider_height"
            android:background="@color/divider" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_chapters"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingTop="4dp"
            android:paddingBottom="8dp"
            android:scrollbars="none"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
