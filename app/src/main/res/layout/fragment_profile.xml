<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 头部区域 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/profile_header_height"
                android:background="@drawable/bg_profile_header"
                android:gravity="center_horizontal">

                <FrameLayout
                    android:id="@+id/fl_avatar"
                    android:layout_width="@dimen/profile_avatar_size"
                    android:layout_height="@dimen/profile_avatar_size"
                    android:layout_marginTop="36dp">

                    <ImageView
                        android:id="@+id/iv_profile_avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_profile_avatar"
                        android:contentDescription="@string/quick_mine"
                        android:scaleType="centerCrop" />
                </FrameLayout>

                <!-- 未登录状态：显示登录按钮 -->
                <TextView
                    android:id="@+id/btn_login"
                    android:layout_width="@dimen/profile_login_btn_width"
                    android:layout_height="@dimen/profile_login_btn_height"
                    android:layout_below="@id/fl_avatar"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_profile_login_btn"
                    android:gravity="center"
                    android:text="@string/profile_click_login"
                    android:textColor="@color/primary_red"
                    android:textSize="@dimen/text_body" />

                <!-- 已登录状态：显示昵称 -->
                <TextView
                    android:id="@+id/tv_nickname"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/fl_avatar"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="14dp"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_large"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_login_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/btn_login"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="8dp"
                    android:text="@string/profile_login_desc"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_micro" />

                <!-- 编辑头像按钮（已登录时显示） -->
                <ImageView
                    android:id="@+id/iv_edit_avatar"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignEnd="@id/fl_avatar"
                    android:layout_alignBottom="@id/fl_avatar"
                    android:background="@drawable/bg_avatar_placeholder"
                    android:contentDescription="编辑头像"
                    android:padding="4dp"
                    android:src="@drawable/ic_camera"
                    android:visibility="gone" />
            </RelativeLayout>

            <!-- 数据统计卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <LinearLayout
                    android:id="@+id/ll_shelf_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_profile_data_card"
                    android:elevation="@dimen/elevation_2dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/profile_data_card_padding">

                    <TextView
                        android:id="@+id/tv_shelf_num"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_shelf_num"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/profile_data_num_size"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/profile_shelf_count"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/profile_data_label_size" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_profile_data_card"
                    android:elevation="@dimen/elevation_2dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/profile_data_card_padding">

                    <TextView
                        android:id="@+id/tv_time_num"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_time_num"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/profile_data_num_size"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/profile_time_count"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/profile_data_label_size" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_profile_data_card"
                    android:elevation="@dimen/elevation_2dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/profile_data_card_padding">

                    <TextView
                        android:id="@+id/tv_coin_num"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_coin_num"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/profile_data_num_size"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/profile_coin_count"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/profile_data_label_size" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@color/app_background" />

            <!-- 成为创作者 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="vertical">

                <RelativeLayout
                    android:id="@+id/ll_menu_creator"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/profile_menu_item_height"
                    android:background="?attr/selectableItemBackground"
                    android:paddingStart="@dimen/padding_horizontal"
                    android:paddingEnd="@dimen/padding_horizontal">

                    <ImageView
                        android:id="@+id/iv_icon_creator"
                        android:layout_width="@dimen/profile_menu_icon_size"
                        android:layout_height="@dimen/profile_menu_icon_size"
                        android:layout_centerVertical="true"
                        android:contentDescription="成为创作者"
                        android:src="@drawable/ic_create_new"
                        app:tint="@color/primary_red" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp"
                        android:layout_toEndOf="@id/iv_icon_creator"
                        android:text="成为创作者"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/profile_menu_text_size" />

                    <ImageView
                        android:layout_width="@dimen/profile_arrow_size"
                        android:layout_height="@dimen/profile_arrow_size"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="成为创作者"
                        android:src="@drawable/ic_arrow_right" />
                </RelativeLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@color/app_background" />

            <!-- 菜单列表 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="vertical">

                <RelativeLayout
                    android:id="@+id/ll_menu_history"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/profile_menu_item_height"
                    android:background="?attr/selectableItemBackground"
                    android:paddingStart="@dimen/padding_horizontal"
                    android:paddingEnd="@dimen/padding_horizontal">

                    <ImageView
                        android:id="@+id/iv_icon_history"
                        android:layout_width="@dimen/profile_menu_icon_size"
                        android:layout_height="@dimen/profile_menu_icon_size"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/profile_menu_history"
                        android:src="@drawable/ic_history" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp"
                        android:layout_toEndOf="@id/iv_icon_history"
                        android:text="@string/profile_menu_history"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/profile_menu_text_size" />

                    <ImageView
                        android:layout_width="@dimen/profile_arrow_size"
                        android:layout_height="@dimen/profile_arrow_size"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/profile_menu_history"
                        android:src="@drawable/ic_arrow_right" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/divider_height"
                    android:layout_marginStart="46dp"
                    android:background="@color/divider" />

                <RelativeLayout
                    android:id="@+id/ll_menu_cache"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/profile_menu_item_height"
                    android:background="?attr/selectableItemBackground"
                    android:paddingStart="@dimen/padding_horizontal"
                    android:paddingEnd="@dimen/padding_horizontal">

                    <ImageView
                        android:id="@+id/iv_icon_cache"
                        android:layout_width="@dimen/profile_menu_icon_size"
                        android:layout_height="@dimen/profile_menu_icon_size"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/profile_menu_cache"
                        android:src="@drawable/ic_cache" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp"
                        android:layout_toEndOf="@id/iv_icon_cache"
                        android:text="@string/profile_menu_cache"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/profile_menu_text_size" />

                    <ImageView
                        android:layout_width="@dimen/profile_arrow_size"
                        android:layout_height="@dimen/profile_arrow_size"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/profile_menu_cache"
                        android:src="@drawable/ic_arrow_right" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/divider_height"
                    android:layout_marginStart="46dp"
                    android:background="@color/divider" />

                <RelativeLayout
                    android:id="@+id/ll_menu_rewards"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/profile_menu_item_height"
                    android:background="?attr/selectableItemBackground"
                    android:paddingStart="@dimen/padding_horizontal"
                    android:paddingEnd="@dimen/padding_horizontal">

                    <ImageView
                        android:id="@+id/iv_icon_rewards"
                        android:layout_width="@dimen/profile_menu_icon_size"
                        android:layout_height="@dimen/profile_menu_icon_size"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/profile_menu_rewards"
                        android:src="@drawable/ic_rewards" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp"
                        android:layout_toEndOf="@id/iv_icon_rewards"
                        android:text="@string/profile_menu_rewards"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/profile_menu_text_size" />

                    <ImageView
                        android:layout_width="@dimen/profile_arrow_size"
                        android:layout_height="@dimen/profile_arrow_size"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/profile_menu_rewards"
                        android:src="@drawable/ic_arrow_right" />
                </RelativeLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@color/app_background" />

            <!-- 设置区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="vertical">

                <RelativeLayout
                    android:id="@+id/ll_menu_night"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/profile_menu_item_height"
                    android:paddingStart="@dimen/padding_horizontal"
                    android:paddingEnd="@dimen/padding_horizontal">

                    <ImageView
                        android:id="@+id/iv_icon_night"
                        android:layout_width="@dimen/profile_menu_icon_size"
                        android:layout_height="@dimen/profile_menu_icon_size"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/profile_menu_night"
                        android:src="@drawable/ic_night_mode" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp"
                        android:layout_toEndOf="@id/iv_icon_night"
                        android:text="@string/profile_menu_night"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/profile_menu_text_size" />

                    <ToggleButton
                        android:id="@+id/tb_night_mode"
                        android:layout_width="42dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_toggle_track"
                        android:checked="false"
                        android:textOff=""
                        android:textOn="" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/divider_height"
                    android:layout_marginStart="46dp"
                    android:background="@color/divider" />

                <RelativeLayout
                    android:id="@+id/ll_menu_help"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/profile_menu_item_height"
                    android:background="?attr/selectableItemBackground"
                    android:paddingStart="@dimen/padding_horizontal"
                    android:paddingEnd="@dimen/padding_horizontal">

                    <ImageView
                        android:id="@+id/iv_icon_help"
                        android:layout_width="@dimen/profile_menu_icon_size"
                        android:layout_height="@dimen/profile_menu_icon_size"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/profile_menu_help"
                        android:src="@drawable/ic_help" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp"
                        android:layout_toEndOf="@id/iv_icon_help"
                        android:text="@string/profile_menu_help"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/profile_menu_text_size" />

                    <ImageView
                        android:layout_width="@dimen/profile_arrow_size"
                        android:layout_height="@dimen/profile_arrow_size"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/profile_menu_help"
                        android:src="@drawable/ic_arrow_right" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/divider_height"
                    android:layout_marginStart="46dp"
                    android:background="@color/divider" />

                <RelativeLayout
                    android:id="@+id/ll_menu_settings"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/profile_menu_item_height"
                    android:background="?attr/selectableItemBackground"
                    android:paddingStart="@dimen/padding_horizontal"
                    android:paddingEnd="@dimen/padding_horizontal">

                    <ImageView
                        android:id="@+id/iv_icon_settings"
                        android:layout_width="@dimen/profile_menu_icon_size"
                        android:layout_height="@dimen/profile_menu_icon_size"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/profile_menu_settings"
                        android:src="@drawable/ic_settings" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp"
                        android:layout_toEndOf="@id/iv_icon_settings"
                        android:text="@string/profile_menu_settings"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/profile_menu_text_size" />

                    <ImageView
                        android:layout_width="@dimen/profile_arrow_size"
                        android:layout_height="@dimen/profile_arrow_size"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/profile_menu_settings"
                        android:src="@drawable/ic_arrow_right" />
                </RelativeLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@color/app_background" />

            <!-- 登出按钮（已登录时显示） -->
            <TextView
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@color/white"
                android:gravity="center"
                android:text="退出登录"
                android:textColor="@color/primary_red"
                android:textSize="@dimen/text_body"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
