<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:orientation="vertical">

    <!-- ==================== 1. 顶部栏 ==================== -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/detail_top_bar_height"
        android:background="@color/white"
        android:elevation="@dimen/elevation_2dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="@dimen/detail_top_icon_size"
            android:layout_height="@dimen/detail_top_icon_size"
            android:layout_centerVertical="true"
            android:contentDescription="@string/detail_title"
            android:padding="4dp"
            android:src="@drawable/ic_back_arrow" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/detail_title"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_large"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentEnd="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv_favorite"
                android:layout_width="@dimen/detail_top_icon_size"
                android:layout_height="@dimen/detail_top_icon_size"
                android:contentDescription="@string/detail_favorite"
                android:padding="4dp"
                android:src="@drawable/ic_star_empty" />

            <ImageView
                android:id="@+id/iv_more_menu"
                android:layout_width="@dimen/detail_top_icon_size"
                android:layout_height="@dimen/detail_top_icon_size"
                android:layout_marginStart="4dp"
                android:contentDescription="@string/detail_title"
                android:padding="4dp"
                android:src="@drawable/ic_more_menu" />

            <ImageView
                android:id="@+id/iv_share"
                android:layout_width="@dimen/detail_top_icon_size"
                android:layout_height="@dimen/detail_top_icon_size"
                android:layout_marginStart="4dp"
                android:contentDescription="@string/detail_title"
                android:padding="4dp"
                android:src="@drawable/ic_share" />
        </LinearLayout>
    </RelativeLayout>

    <!-- ==================== 可滚动内容区域 ==================== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ==================== 2. 书籍封面区域 ==================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="24dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/iv_detail_cover"
                    android:layout_width="@dimen/detail_cover_width"
                    android:layout_height="@dimen/detail_cover_height"
                    android:background="@drawable/bg_book_cover_placeholder"
                    android:contentDescription="@string/book_title_1"
                    android:elevation="@dimen/elevation_4dp"
                    android:scaleType="centerCrop" />

                <TextView
                    android:id="@+id/tv_detail_book_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/book_title_1"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_xlarge"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/divider_height"
                android:background="@color/divider" />

            <!-- ==================== 3. 作者信息（可点击跳转作者主页） ==================== -->
            <LinearLayout
                android:id="@+id/ll_author_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/padding_horizontal"
                android:paddingEnd="@dimen/padding_horizontal"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tv_detail_author"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/detail_author"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/detail_info_text_size" />

                <TextView
                    android:id="@+id/tv_detail_word_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@string/detail_word_count"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/detail_info_text_size" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="6dp"
                    android:contentDescription="@string/author_profile_title"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/text_hint" />
            </LinearLayout>

            <!-- ==================== 4. 评分行 ==================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/padding_horizontal"
                android:paddingEnd="@dimen/padding_horizontal"
                android:paddingBottom="12dp">

                <ImageView
                    android:layout_width="@dimen/detail_star_size"
                    android:layout_height="@dimen/detail_star_size"
                    android:contentDescription="@string/detail_rating"
                    android:src="@drawable/ic_star_filled" />

                <ImageView
                    android:layout_width="@dimen/detail_star_size"
                    android:layout_height="@dimen/detail_star_size"
                    android:contentDescription="@string/detail_rating"
                    android:src="@drawable/ic_star_filled" />

                <ImageView
                    android:layout_width="@dimen/detail_star_size"
                    android:layout_height="@dimen/detail_star_size"
                    android:contentDescription="@string/detail_rating"
                    android:src="@drawable/ic_star_filled" />

                <ImageView
                    android:layout_width="@dimen/detail_star_size"
                    android:layout_height="@dimen/detail_star_size"
                    android:contentDescription="@string/detail_rating"
                    android:src="@drawable/ic_star_filled" />

                <ImageView
                    android:layout_width="@dimen/detail_star_size"
                    android:layout_height="@dimen/detail_star_size"
                    android:contentDescription="@string/detail_rating"
                    android:src="@drawable/ic_star_half" />

                <TextView
                    android:id="@+id/tv_detail_rating_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/detail_rating"
                    android:textColor="@color/star_gold"
                    android:textSize="@dimen/detail_rating_text_size"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_detail_rating_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/detail_rating_count"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_small" />
            </LinearLayout>

            <!-- ==================== 5. 两个大按钮 ==================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="horizontal"
                android:paddingStart="@dimen/padding_horizontal"
                android:paddingEnd="@dimen/padding_horizontal"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/btn_add_shelf"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/detail_btn_height"
                    android:layout_marginEnd="12dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_add_shelf"
                    android:gravity="center"
                    android:text="@string/book_add_shelf"
                    android:textColor="@color/primary_red"
                    android:textSize="@dimen/detail_btn_text_size" />

                <TextView
                    android:id="@+id/btn_start_read"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/detail_btn_height"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_read_gradient"
                    android:gravity="center"
                    android:text="@string/detail_start_reading"
                    android:textColor="@color/white"
                    android:textSize="@dimen/detail_btn_text_size"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ==================== 区域分隔 ==================== -->
            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@color/app_background" />

            <!-- ==================== 6. 简介区域 ==================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="vertical"
                android:paddingStart="@dimen/padding_horizontal"
                android:paddingEnd="@dimen/padding_horizontal"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/detail_synopsis_title"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/section_title_size"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_detail_synopsis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:ellipsize="end"
                    android:lineSpacingExtra="4dp"
                    android:maxLines="4"
                    android:text="@string/detail_synopsis_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_body" />

                <TextView
                    android:id="@+id/tv_synopsis_expand"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="6dp"
                    android:padding="4dp"
                    android:text="@string/detail_synopsis_expand"
                    android:textColor="@color/primary_red"
                    android:textSize="@dimen/text_small" />
            </LinearLayout>

            <!-- ==================== 区域分隔 ==================== -->
            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@color/app_background" />

            <!-- ==================== 7. 标签区域 ==================== -->
            <LinearLayout
                android:id="@+id/ll_tags_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="vertical"
                android:paddingStart="@dimen/padding_horizontal"
                android:paddingEnd="@dimen/padding_horizontal"
                android:paddingTop="12dp"
                android:paddingBottom="6dp">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/ll_tags"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="8dp" />
                </HorizontalScrollView>
            </LinearLayout>

            <!-- ==================== 区域分隔 ==================== -->
            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@color/app_background" />

            <!-- ==================== 8. 目录预览 ==================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="vertical"
                android:paddingStart="@dimen/padding_horizontal"
                android:paddingEnd="@dimen/padding_horizontal"
                android:paddingTop="14dp"
                android:paddingBottom="4dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tv_toc_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:text="@string/detail_toc_title"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/section_title_size"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_toc_view_all"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:padding="4dp"
                        android:text="@string/detail_toc_view_all"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_small" />
                </RelativeLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_detail_chapters"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:scrollbars="none" />
            </LinearLayout>

            <!-- ==================== 区域分隔 ==================== -->
            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@color/app_background" />

            <!-- ==================== 9. 热门书评 ==================== -->
            <LinearLayout
                android:id="@+id/ll_reviews_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="vertical"
                android:paddingStart="@dimen/padding_horizontal"
                android:paddingEnd="@dimen/padding_horizontal"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/detail_reviews_title"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/section_title_size"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_reviews_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_small" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_reviews_view_all"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:padding="4dp"
                        android:text="@string/detail_toc_view_all"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_small" />
                </RelativeLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_reviews_preview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                <TextView
                    android:id="@+id/tv_reviews_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingTop="20dp"
                    android:paddingBottom="20dp"
                    android:text="@string/detail_reviews_empty"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_body"
                    android:visibility="gone" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@color/app_background" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ==================== 10. 底部悬浮条 ==================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/detail_bottom_bar_height"
        android:background="@color/bottom_nav_bg"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/padding_horizontal"
        android:paddingEnd="8dp">

        <LinearLayout
            android:id="@+id/ll_comment_input"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:background="@drawable/bg_comment_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="@string/detail_comment_hint"
                android:src="@drawable/ic_comment" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/detail_comment_hint"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/text_body" />
        </LinearLayout>

        <ImageView
            android:id="@+id/iv_bottom_like"
            android:layout_width="@dimen/detail_top_icon_size"
            android:layout_height="@dimen/detail_top_icon_size"
            android:layout_marginStart="12dp"
            android:contentDescription="@string/detail_comment_hint"
            android:padding="3dp"
            android:src="@drawable/ic_thumb_up" />

        <ImageView
            android:id="@+id/iv_bottom_favorite"
            android:layout_width="@dimen/detail_top_icon_size"
            android:layout_height="@dimen/detail_top_icon_size"
            android:layout_marginStart="4dp"
            android:contentDescription="@string/detail_comment_hint"
            android:padding="3dp"
            android:src="@drawable/ic_favorite_border" />

        <ImageView
            android:id="@+id/iv_bottom_share"
            android:layout_width="@dimen/detail_top_icon_size"
            android:layout_height="@dimen/detail_top_icon_size"
            android:layout_marginStart="4dp"
            android:contentDescription="@string/detail_comment_hint"
            android:padding="3dp"
            android:src="@drawable/ic_share" />
    </LinearLayout>

</LinearLayout>
